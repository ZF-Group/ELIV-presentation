            },
            {
              "$ref": "#/$defs/BooleanDatatype"
            },
            {
              "$ref": "#/$defs/StructDatatype"
            }
          ],
          "title": "Datatype"
        },
        "ArraySize": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "description": "If the method datatype is given as an arry the array size shall be specified with this field",
          "title": "Arraysize"
        }
      },
      "required": [
        "Name",
        "Datatype",
        "ArraySize"
      ],
      "title": "MethodDatatype",
      "type": "object"
    },
