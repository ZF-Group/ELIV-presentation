          "title": "Maxvalue"
        },
        "Offset": {
          "description": "Offset of the numerical signal after scaling",
          "title": "Offset",
          "type": "number"
        },
        "Scaling": {
          "description": "Scaling factor of the numerical signal",
          "title": "Scaling",
          "type": "number"
        },
        "Unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unit of the signal",
          "title": "Unit"
        },
        "Default": {
          "description": "Default value of the signal",
          "title": "Default",
          "type": "number"
        },
        "InitValue": {
          "description": "Init value of the signal",
          "title": "Initvalue",
          "type": "number"
        }
      },
      "required": [
        "Datatype",
        "MinValue",
        "MaxValue",
        "Offset",
        "Scaling",
        "Unit",
