        }
      },
      "required": [
        "Name",
        "Description",
        "Datatype",
        "ErrorList"
      ],
      "title": "SafetyReaction",
      "type": "object"
    },
    "SchedulingInfo": {
      "properties": {
        "Runtype": {
          "description": "Runtype of the function/runnable, can be Cyclic or EventBased",
          "pattern": "^(Cyclic|EventBased)$",
          "title": "Runtype",
          "type": "string"
        },
        "CycleTime": {
          "description": "Cycle time of the function runnable in ms. Set cycletime to 0 (or -1) if function/runnable is only eventbased.",
          "title": "Cycletime",
          "type": "number"
        },
        "PrevFunction": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Init/Cyclic/OtherRunnableName after this Runnable the above function or Runnable has to run",
          "title": "Prevfunction"
        },
        "ExecOffset": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "description": "Runnable First Execution Offset/Initial delay in ms",
          "title": "Execoffset"
        },
        "Scheduling": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Preemptive/Non-Preemptive/RR/FIFO/EDF etc.",
          "title": "Scheduling"
        },
        "DebounceDelay": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
