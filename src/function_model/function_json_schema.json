        "uint8",
        "uint16",
        "uint32",
        "uint64"
      ],
      "title": "NumericalDatatypes",
      "type": "string"
    },
    "Parameter": {
      "properties": {
        "Name": {
          "description": "Name of the parameter",
          "title": "Name",
          "type": "string"
        },
        "Description": {
          "description": "Description of the parameter",
          "title": "Description",
          "type": "string"
        },
        "AsilInfo": {
