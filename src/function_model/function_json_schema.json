          "title": "Prevrunnable"
        },
        "ExecOffset": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Execution offset",
          "title": "Execoffset"
        },
        "ParallelProcessing": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Indicates if parallel processing is enabled",
          "title": "Parallelprocessing"
        },
        "AsilLevel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ASIL level of the function",
          "title": "Asillevel"
        },
        "Watchdog": {
          "anyOf": [
            {
              "$ref": "#/$defs/WatchdogItem"
            },
            {
              "type": "null"
            }
          ],
          "description": "Watchdog Configuration for the runnable/Executable. Min, Max and Ref for AliveSupervision in Cycles count, Deadline Supervision in ms time"
        },
        "Scheduling": {
          "description": "Scheduling type, e.g., Pre-emptive or Non-Preemptive",
          "title": "Scheduling",
          "type": "string"
        },
        "DebounceDelay": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Delay after which the function should run",
          "title": "Debouncedelay"
        },
        "Priority": {
          "description": "Priority description",
          "title": "Priority",
          "type": "string"
        },
        "EventList": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Associated events list with which the function is trigegred, only for future scope",
          "title": "Eventlist"
        },
        "funcContractList": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/funcContract"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of function contracts",
          "title": "Funccontractlist"
        }
      },
      "required": [
        "Name",
        "Description",
        "Runtype",
        "Watchdog",
        "Scheduling",
        "Priority"
      ],
      "title": "function",
      "type": "object"
    }
  },
  "properties": {
    "MetaInfo": {
      "$ref": "#/$defs/MetaInfoItem",
      "description": "Metadata information"
    },
    "FunctionInfo": {
      "$ref": "#/$defs/FunctionDetails",
      "description": "Software Function Name and description"
    },
    "ComponentList": {
      "description": "List of components in a function",
      "items": {
        "$ref": "#/$defs/Component"
      },
      "title": "Componentlist",
      "type": "array"
    },
    "ModesList": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/Mode"
          },
          "type": "array"
        },
        {
          "type": "null"
